# 서버 실행 환경
PORT=8900
OMP_NUM_THREADS=1     # ThreadPoolExecutor와 OpenMP 스레드 충돌 방지. 변경 시 성능 영향.

# 파일 저장 경로
UPLOAD_DIR=uploads
TEMP_DIR=temp

# PDF 처리 튜닝
PDF_DPI=300           # 낮추면 속도 향상, OCR 정확도 하락

# Tesseract 설정
TESSERACT_CONFIG="--psm 6 --oem 3 -c preserve_interword_spaces=1"
TESSERACT_LANG=kor+eng  # 추가 언어는 tesseract-ocr-<lang> 패키지 설치 필요

# OCR 튜닝값
# EASYOCR_LANGUAGES 제거됨 (EasyOCR 제거, VLM 연동 예정)
OCR_TEXT_THRESHOLD=50
OCR_MAX_WORKERS=4
OCR_WORD_CONF_MIN=30

# VLM 폴백 트리거 등급 (JSON 배열 형식 필수)
# very_low / low / medium / high 중 선택
VLM_FALLBACK_FLAGS=["very_low"]

# VLM (GPT-4V) 설정
OPENAI_API_KEY=           # OpenAI API 키. 비어있으면 VLM 폴백 비활성화.
VLM_MODEL=gpt-4o          # 사용할 모델. gpt-4o-mini로 낮추면 비용 절감.
VLM_MAX_TOKENS=1024       # 응답 최대 토큰. 텍스트가 잘리면 늘린다.

# Tesseract 바이너리 경로 (기본: 시스템 PATH, 필요 시 절대경로 지정)
# TESSERACT_CMD=/usr/bin/tesseract
